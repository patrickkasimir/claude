[
  {
    "id": "_pagemanager",
    "name": "PageManager (Klasse)",
    "icon": "🏗️",
    "description": "Generische JS-Klasse die alle CRUD-Seiten antreibt. Eine Instanz pro Entität, konfiguriert über ein Config-Objekt.",
    "version": "1.0",
    "pagemanager": true,
    "state": [
      { "property": "data",          "type": "Array",    "description": "Alle Datensätze der Entität — geladen via GET /[apiPath]" },
      { "property": "viewMode",      "type": "String",   "description": "'kanban' oder 'list' — steuert welche Ansicht gerendert wird" },
      { "property": "kanbanGroup",   "type": "String",   "description": "Aktuelles Gruppierungsfeld für Kanban (Default: cfg.defaultGroup)" },
      { "property": "activeChips",   "type": "Array",    "description": "Aktive Such-Chips [{field, value, label}] — werden auf data gefiltert" },
      { "property": "selectedIds",   "type": "Set",      "description": "IDs der selektierten Listenzeilen — für Massenbearbeitung" },
      { "property": "sortCol",       "type": "String",   "description": "Aktuell sortierte Spalte (null = keine Sortierung)" },
      { "property": "sortDir",       "type": "String",   "description": "'asc' oder 'desc'" },
      { "property": "colDragSrc",    "type": "String",   "description": "Spalten-Key der gerade gezogenen Header-Spalte (Reorder)" },
      { "property": "colSettings",   "type": "Object",   "description": "{visible: {key→bool}, widths: {key→px}, order: [keys]} — in localStorage" },
      { "property": "_editId",       "type": "Number",   "description": "ID des aktuell geöffneten Eintrags (null = neu)" }
    ],
    "methods": [
      { "method": "init()",               "access": "public",  "description": "Lädt data, bindet alle Event-Handler, rendert erste Ansicht. Wird einmalig beim App-Start aufgerufen." },
      { "method": "renderPage()",         "access": "public",  "description": "Rendert Kanban oder Liste je nach viewMode. Wird nach jedem Save/Delete aufgerufen." },
      { "method": "openDetail(id)",       "access": "public",  "description": "Öffnet Detailformular für bestehenden Eintrag. Ruft cfg.renderDetail(), lädt Chatter." },
      { "method": "openNew()",            "access": "public",  "description": "Öffnet leeres Detailformular für neuen Eintrag. Ruft cfg.renderDetail(null)." },
      { "method": "closeDetail()",        "access": "public",  "description": "Schließt Detailformular, zeigt Liste/Kanban wieder. Überschreibbar in Subklassen." },
      { "method": "_filtered()",          "access": "private", "description": "Gibt data gefiltert nach activeChips zurück. Nutzt cfg.filterItem(item, chip)." },
      { "method": "_sorted(data)",        "access": "private", "description": "Sortiert Array nach sortCol/sortDir. Nutzt optional cfg.sortValue(item, col)." },
      { "method": "_renderKanban()",      "access": "private", "description": "Rendert Kanban-Spalten aus groupByOptions. Drag&Drop per mousedown/mousemove/mouseup." },
      { "method": "_renderListHeaders()", "access": "private", "description": "Rendert th-Elemente: Sort-Click, Resize-Handle, Drag-Reorder, Select-All-Checkbox." },
      { "method": "_renderListBody()",    "access": "private", "description": "Rendert tr-Elemente: Checkboxen, Inline-Edit-Handler, Row-Click→Detail." },
      { "method": "_saveField(id,f,v)",   "access": "private", "description": "Speichert ein Feld via PUT. Bei Mehrfachauswahl: Bestätigungs-Modal, dann PUT für alle selectedIds." },
      { "method": "_bindToolbar()",       "access": "private", "description": "Bindet Kanban/Liste Toggle, ▾ Sichtbarkeit, Sort-Menü, Neu-Button, Spalten-Popup." },
      { "method": "_bindSearch()",        "access": "private", "description": "Bindet Odoo-Suchfeld: Dropdown, Chip-Erzeugung, Filter-Aktualisierung." },
      { "method": "_bindDetail()",        "access": "private", "description": "Bindet Speichern/Löschen/Abbrechen-Buttons im Detailformular." },
      { "method": "_buildColVisPopup()",  "access": "private", "description": "Erzeugt Checkbox-Liste zum Ein-/Ausblenden von Spalten." },
      { "method": "_saveColSettings()",   "access": "private", "description": "Schreibt colSettings in localStorage (Key: apppp_[entity]_col_settings)." },
      { "method": "_saveDetail()",        "access": "private", "description": "POST (neu) oder PUT (bestehend) mit cfg.collectForm(). Schließt Panel danach." }
    ],
    "config": [
      { "key": "entity",           "required": true,  "description": "Eindeutiger Name (z.B. 'tasks'). Basis für localStorage-Key." },
      { "key": "apiPath",          "required": true,  "description": "REST-Pfad (z.B. '/incidents'). Basis für GET/POST/PUT/DELETE." },
      { "key": "columns",          "required": true,  "description": "Array: [{key, label, defaultOn, width}]. Definiert Listenansicht." },
      { "key": "groupByOptions",   "required": true,  "description": "Array: [{key, label}]. Optionen für Kanban-Gruppierungs-▾." },
      { "key": "defaultGroup",     "required": false, "description": "Key aus groupByOptions für initialen Kanban-Grouping." },
      { "key": "searchFields",     "required": true,  "description": "Array: [{key, label, type, values?}]. Felder für Odoo-Suchfeld-Dropdown." },
      { "key": "editableFields",   "required": false, "description": "Keys der Spalten die inline editierbar sind (Klick→Input/Select)." },
      { "key": "enumFields",       "required": false, "description": "Objekt: {field: [values]}. Definiert Select-Optionen für Inline-Editing." },
      { "key": "cellRenderer",     "required": true,  "description": "Funktion(item, col, pm)→String. Gibt den td-Inhalt zurück (ohne <td>-Tag)." },
      { "key": "renderCard",       "required": true,  "description": "Funktion(item, pm)→HTML. Rendert eine Kanban-Karte." },
      { "key": "renderDetail",     "required": true,  "description": "Funktion(item|null, pm). Befüllt das Detailformular. item=null bei neuem Eintrag." },
      { "key": "collectForm",      "required": true,  "description": "Funktion(pm)→Object. Liest Formularfelder aus, gibt Body für POST/PUT zurück." },
      { "key": "filterItem",       "required": true,  "description": "Funktion(item, chip)→bool. Prüft ob item einen Such-Chip erfüllt." },
      { "key": "getTitle",         "required": true,  "description": "Funktion(item)→String. Gibt Breadcrumb-Label für einen Eintrag zurück." },
      { "key": "onAfterSave",      "required": false, "description": "Async Funktion(pm). Hook nach erfolgreichem Save (z.B. Users nachladen)." },
      { "key": "onAfterDelete",    "required": false, "description": "Async Funktion(pm). Hook nach erfolgreichem Delete." },
      { "key": "sortValue",        "required": false, "description": "Funktion(item, col)→String. Überschreibt Sort-Wert (Default: item[col])." },
      { "key": "buildLeadHeaders", "required": false, "description": "Funktion(head, pm). Fügt zusätzliche th vor den Datenspalten ein (z.B. Avatar-Spalte)." },
      { "key": "extraLeadCells",   "required": false, "description": "Funktion(item, pm)→HTML. Gibt td-Inhalt für extra Spalten vor den Datenspalten zurück." },
      { "key": "chatter",          "required": false, "description": "Config-Objekt für Chatter-Panel: {entityPath, addNoteBtnId, feedElId, composeElId, inputElId, fileInputId, sendBtnId}." },
      { "key": "kanbanBtnId",      "required": true,  "description": "ID des Kanban-Toggle-Buttons." },
      { "key": "listBtnId",        "required": true,  "description": "ID des Listen-Toggle-Buttons." },
      { "key": "kanbanWrapId",     "required": true,  "description": "ID des Kanban-Wrapper-Divs (bekommt .active-Klasse)." },
      { "key": "listWrapId",       "required": true,  "description": "ID des Listen-Wrapper-Divs (bekommt .active-Klasse)." },
      { "key": "kanbanElId",       "required": true,  "description": "ID des Kanban-Containers (<div> mit flex)." },
      { "key": "listViewElId",     "required": true,  "description": "ID des Listenansicht-Containers." },
      { "key": "listHeadId",       "required": true,  "description": "ID des <tr> im <thead> der Listenansicht." },
      { "key": "listBodyId",       "required": true,  "description": "ID des <tbody> der Listenansicht." },
      { "key": "detailElId",       "required": true,  "description": "ID des Detail-Panels (<div> mit .visible-Klasse)." },
      { "key": "breadcrumbElId",   "required": true,  "description": "ID des Breadcrumb-Divs." },
      { "key": "listPageElId",     "required": true,  "description": "ID des Listen-/Kanban-Seiten-Containers (wird bei Detail ausgeblendet)." },
      { "key": "saveBtnId",        "required": true,  "description": "ID des Speichern-Buttons im Detailformular." },
      { "key": "deleteBtnId",      "required": true,  "description": "ID des Löschen-Buttons im Detailformular." },
      { "key": "cancelBtnId",      "required": true,  "description": "ID des Abbrechen-Buttons im Detailformular." },
      { "key": "newBtnId",         "required": true,  "description": "ID des '+ Neu'-Buttons in der Toolbar." },
      { "key": "sortToggleId",     "required": true,  "description": "ID des Gruppierungs-▾-Buttons." },
      { "key": "sortMenuId",       "required": true,  "description": "ID des Gruppierungs-Dropdown-Menüs." },
      { "key": "colVisToggleId",   "required": true,  "description": "ID des Spalten-▾-Buttons." },
      { "key": "colVisPopupId",    "required": true,  "description": "ID des Spalten-Sichtbarkeits-Popups." },
      { "key": "searchWrapId",     "required": true,  "description": "ID des Odoo-Suchfeld-Wrappers." },
      { "key": "searchInputId",    "required": true,  "description": "ID des Odoo-Sucheingabefeldes." },
      { "key": "searchDropdownId", "required": true,  "description": "ID des Odoo-Such-Dropdowns." }
    ],
    "subclasses": [
      { "name": "UsersPageManager",     "overrides": "closeDetail()", "reason": "Users-Detailformular liegt auf einer eigenen Seite (#user-detail statt innerhalb der Listen-Seite). Avatar-Upload-Panel wird zusätzlich angezeigt." },
      { "name": "IncidentsPageManager", "overrides": "closeDetail()", "reason": "Incidents-Detailformular liegt auf einer eigenen Seite (#incident-detail). SLA/Prioritäts-Felder werden beim Öffnen zusätzlich initialisiert." }
    ],
    "instances": [
      { "name": "tasksPM",     "class": "PageManager",          "entity": "tasks",     "apiPath": "/tasks",     "storageKey": "apppp_tasks_col_settings" },
      { "name": "usersPM",     "class": "UsersPageManager",     "entity": "users",     "apiPath": "/users",     "storageKey": "apppp_users_col_settings" },
      { "name": "incidentsPM", "class": "IncidentsPageManager", "entity": "incidents", "apiPath": "/incidents", "storageKey": "apppp_incidents_col_settings" }
    ]
  },
  {
    "id": "_generic",
    "name": "Strukturelemente (generisch)",
    "icon": "⚙️",
    "description": "Alle strukturellen Features die in jeder CRUD-App immer vorhanden sind — unabhängig vom Prozess.",
    "version": "1.0",
    "generic": true,
    "toolbar": [
      { "element": "+ Neu Button",          "description": "Öffnet leeres Detailformular. Label konfigurierbar (Default: '+ Neu')." },
      { "element": "Odoo-Suchfeld",         "description": "Zweistufige Suche: Klick öffnet Feld-Dropdown → Feld auswählen → Wert eingeben → Enter erzeugt Such-Chip. Mehrere Chips kombinieren sich per UND. ✕ entfernt einzelne Chips." },
      { "element": "Kanban-Toggle (⊞)",     "description": "Wechselt zur Kanban-Ansicht. Button wird links-rund und verbindet visuell mit dem Gruppierungs-▾." },
      { "element": "Gruppierungs-▾",        "description": "Erscheint nur wenn Kanban aktiv. Dropdown zur Auswahl des Kanban-Gruppierungsfeldes." },
      { "element": "Listen-Toggle (☰)",     "description": "Wechselt zur Listenansicht. Button wird links-rund und verbindet visuell mit dem Spalten-▾." },
      { "element": "Spalten-▾",             "description": "Erscheint nur wenn Liste aktiv. Checkbox-Dropdown zum Ein-/Ausblenden von Spalten." }
    ],
    "kanban": [
      { "element": "Dynamische Spalten",    "description": "Spalten werden aus dem konfigurierten Gruppierungsfeld generiert. Spalte 'Ohne [Feld]' für NULL-Werte." },
      { "element": "Drag & Drop",           "description": "Karten per Maus zwischen Spalten verschieben. Ghost-Karte beim Ziehen, Ziel-Spalte wird hervorgehoben. PUT-Request auf Drop." },
      { "element": "Klick → Detail",        "description": "Klick auf eine Karte öffnet das Detailformular des Eintrags." },
      { "element": "Karten-Inhalt",         "description": "App-spezifisch: Welche Felder auf der Karte angezeigt werden, wird pro Prozess konfiguriert." }
    ],
    "list": [
      { "element": "Checkbox-Spalte",       "description": "Erste Spalte: Einzel-Checkbox pro Zeile + 'Alle auswählen' im Header." },
      { "element": "Spalten ein-/ausblenden","description": "Via Spalten-▾. Einstellung wird in localStorage gespeichert (Key: apppp_[entity]_col_settings)." },
      { "element": "Spaltenbreite Resize",  "description": "Ziehbarer Resizer am rechten Rand jedes Spalten-Headers. table-layout: fixed — ändert nur die gezogene Spalte." },
      { "element": "Spalten Drag & Drop",   "description": "Header-Spalten per Drag & Drop umsortieren. Reihenfolge in localStorage gespeichert." },
      { "element": "Sortierung",            "description": "Klick auf Spalten-Label: asc → desc → keine. Aktive Spalte wird grün hervorgehoben + Pfeil." },
      { "element": "Inline-Editing",        "description": "Klick auf editierbare Zelle → input oder select erscheint inline. Enter/Blur speichert. Escape bricht ab. Editierbare Felder sind app-spezifisch." },
      { "element": "Massenbearbeitung",     "description": "Bei Mehrfachauswahl: Feld eines selektierten Eintrags ändern → Bestätigungsdialog 'Für alle X übernehmen?'." },
      { "element": "Zeilen-Highlight",      "description": "Selektierte Zeilen werden mit row-selected CSS-Klasse hervorgehoben." },
      { "element": "Klick → Detail",        "description": "Klick auf Zeile öffnet Detailformular. Gilt nicht bei Klick auf editierbare Zelle oder Checkbox." }
    ],
    "detail": [
      { "element": "Breadcrumb",            "description": "Zurück-Navigation zur Listenansicht." },
      { "element": "2-Spalten-Grid",        "description": "Felder in .detail-grid (1fr 1fr), gruppiert in .detail-section Blöcken." },
      { "element": "Felder",                "description": "App-spezifisch: Welche Felder angezeigt werden." },
      { "element": "Speichern-Button",      "description": "POST (neu) oder PUT (bestehend). Validiert Pflichtfelder." },
      { "element": "Löschen-Button",        "description": "Rot, nur bei bestehenden Einträgen. Öffnet Bestätigungs-Modal." },
      { "element": "Abbrechen-Button",      "description": "Schließt Formular ohne Speichern." },
      { "element": "Bestätigungs-Modal",    "description": "showConfirm(msg, {title, yesLabel, danger}). Titel, Button-Text und Farbe sind konfigurierbar." }
    ],
    "chatter": [
      { "element": "+ Notiz Button",        "description": "Oben rechts im Chatter-Panel. Öffnet Compose-Bereich (standardmäßig verborgen)." },
      { "element": "Chronologischer Feed",  "description": "Neueste Einträge oben. Timestamp, Text, optionaler Dateilink." },
      { "element": "Eintrag löschen",       "description": "Hover auf Eintrag zeigt ✕-Button. DELETE-Request an Backend." },
      { "element": "Datei-Upload",          "description": "Pro Notiz eine Datei anhängbar. multipart/form-data, max. 20 MB. Datei-Link erscheint im Feed." },
      { "element": "Strg+Enter senden",     "description": "Tastaturkürzel zum Absenden der Notiz." },
      { "element": "Panel-Breite",          "description": "640px, sticky rechts neben dem Detailformular." },
      { "element": "Endpoints",             "description": "GET/POST /[entity]/:id/notes, DELETE /[entity]/:id/notes/:noteId" }
    ],
    "modals": [
      { "element": "Toast-Nachrichten",     "description": "Erfolg: grün (#4ade80), Fehler: rot (#f87171). Erscheinen 3 Sekunden, dann fade-out." },
      { "element": "showConfirm()",         "description": "Konfigurierbares Modal: title, yesLabel, danger-Flag (roter Button). Gibt Promise<boolean> zurück." }
    ]
  },
  {
    "id": "tasks",
    "name": "Task Management",
    "icon": "📋",
    "description": "Aufgabenverwaltung mit Kanban-Board, Benutzerzuweisung und Statusverfolgung.",
    "version": "1.0",
    "process_description": "Der Task-Management-Prozess beginnt mit der Erfassung einer Aufgabe durch einen Benutzer. Die Aufgabe durchläuft einen definierten Lebenszyklus: Nach der Erstellung liegt sie im Status 'Offen' und kann einem Benutzer zugewiesen werden. Der Bearbeiter nimmt die Aufgabe 'In Bearbeitung', arbeitet sie ab und stellt sie zur Prüfung bereit ('Review'). Nach erfolgreicher Abnahme wird die Aufgabe als 'Erledigt' markiert. Prioritäten werden automatisch aus den Feldern Auswirkung und Dringlichkeit berechnet, um eine objektive Reihenfolge sicherzustellen. Der gesamte Verlauf inkl. Kommentare und Dateianhänge ist im Chatter nachvollziehbar.",
    "bpmn_steps": [
      { "id": "start",      "type": "start",    "label": "Start",            "lane": "Auftraggeber" },
      { "id": "create",     "type": "task",     "label": "Aufgabe erstellen","lane": "Auftraggeber" },
      { "id": "open",       "type": "task",     "label": "Aufgabe offen",    "lane": "Bearbeiter" },
      { "id": "assign",     "type": "task",     "label": "Zuweisen",         "lane": "Bearbeiter" },
      { "id": "inprog",     "type": "task",     "label": "In Bearbeitung",   "lane": "Bearbeiter" },
      { "id": "gw_review",  "type": "gateway",  "label": "Review?",          "lane": "Bearbeiter" },
      { "id": "review",     "type": "task",     "label": "Review",           "lane": "Auftraggeber" },
      { "id": "gw_ok",      "type": "gateway",  "label": "Akzeptiert?",      "lane": "Auftraggeber" },
      { "id": "done",       "type": "task",     "label": "Erledigt",         "lane": "Bearbeiter" },
      { "id": "end",        "type": "end",      "label": "Ende",             "lane": "Bearbeiter" }
    ],
    "fields": [
      { "key": "title",         "label": "Titel",            "type": "text",     "required": true,  "auto": false },
      { "key": "description",   "label": "Beschreibung",     "type": "textarea", "required": false, "auto": false },
      { "key": "status",        "label": "Status",           "type": "enum",     "required": true,  "auto": false,
        "values": ["offen","in bearbeitung","review","erledigt"] },
      { "key": "auswirkung",    "label": "Auswirkung",       "type": "enum",     "required": false, "auto": false,
        "values": ["niedrig","mittel","hoch"] },
      { "key": "dringlichkeit", "label": "Dringlichkeit",    "type": "enum",     "required": false, "auto": false,
        "values": ["niedrig","mittel","hoch"] },
      { "key": "priority",      "label": "Priorität",        "type": "enum",     "required": false, "auto": true,
        "note": "Berechnet aus Auswirkung × Dringlichkeit",
        "values": ["niedrig","mittel","hoch"] },
      { "key": "user_id",       "label": "Zugewiesen an",    "type": "user",     "required": false, "auto": false },
      { "key": "due_date",      "label": "Fälligkeitsdatum", "type": "date",     "required": false, "auto": false },
      { "key": "created_at",    "label": "Erstellt am",      "type": "datetime", "required": false, "auto": true },
      { "key": "updated_at",    "label": "Aktualisiert am",  "type": "datetime", "required": false, "auto": true }
    ],
    "kanbanGroups": [
      { "key": "status",    "label": "Phase" },
      { "key": "priority",  "label": "Priorität" },
      { "key": "user",      "label": "Benutzer" },
      { "key": "due_date",  "label": "Fälligkeitsdatum", "granularity": ["Tag","Woche","Monat","Jahr"] }
    ],
    "sla": null,
    "features": [
      "Kanban mit Drag & Drop",
      "Listenansicht mit Inline-Editing",
      "Massenbearbeitung",
      "Odoo-Suchfeld mit Chips",
      "Chatter mit Datei-Upload",
      "Prioritäts-Matrix (Auswirkung × Dringlichkeit)",
      "Spalten resize & reorder"
    ]
  },
  {
    "id": "incidents",
    "name": "Incident Management",
    "icon": "🚨",
    "description": "ITIL-konformes Incident Management mit SLA-Tracking, Prioritätsmatrix und Eskalations-Workflow.",
    "version": "1.0",
    "process_description": "Der Incident-Management-Prozess folgt dem ITIL-Standard und beginnt mit der Meldung eines Störfalls durch den Melder. Der Service Desk erfasst, klassifiziert und priorisiert den Incident automatisch anhand der Felder Auswirkung und Dringlichkeit (P1–P4). Bei hoher Priorität (P1/P2) erfolgt sofortige Eskalation zu L2 oder L3. Niedrigere Prioritäten werden zunächst von L1 bearbeitet. Kann L1 den Incident nicht lösen, eskaliert er ebenfalls. Der SLA-Timer läuft ab Erfassung und pausiert bei Status 'Wartend'. Bei Erreichen der Lösung wird der Incident getestet und nach Bestätigung geschlossen. Alle Statuswechsel, Eskalationen und Kommunikation werden im Chatter protokolliert.",
    "bpmn_steps": [
      { "id": "start",     "type": "start",   "label": "Start",              "lane": "Melder" },
      { "id": "report",    "type": "task",    "label": "Incident melden",    "lane": "Melder" },
      { "id": "capture",   "type": "task",    "label": "Erfassen & klassifizieren", "lane": "Service Desk" },
      { "id": "priority",  "type": "task",    "label": "Priorität bestimmen","lane": "Service Desk" },
      { "id": "gw_prio",   "type": "gateway", "label": "Priorität?",         "lane": "Service Desk" },
      { "id": "assign_l1", "type": "task",    "label": "Zuweisen L1",        "lane": "L1 Support" },
      { "id": "diag_l1",   "type": "task",    "label": "Diagnose L1",        "lane": "L1 Support" },
      { "id": "gw_l1",     "type": "gateway", "label": "L1 lösbar?",         "lane": "L1 Support" },
      { "id": "escalate",  "type": "task",    "label": "Eskalieren L2/L3",   "lane": "L2/L3" },
      { "id": "diag_l2",   "type": "task",    "label": "Diagnose & Lösung L2/L3", "lane": "L2/L3" },
      { "id": "waiting",   "type": "event",   "label": "Wartend",            "lane": "L2/L3" },
      { "id": "solve",     "type": "task",    "label": "Lösung anwenden",    "lane": "L1 Support" },
      { "id": "test",      "type": "task",    "label": "Testen",             "lane": "L1 Support" },
      { "id": "gw_test",   "type": "gateway", "label": "Test OK?",           "lane": "Service Desk" },
      { "id": "close",     "type": "task",    "label": "Incident schließen", "lane": "Service Desk" },
      { "id": "end",       "type": "end",     "label": "Ende",               "lane": "Service Desk" }
    ],
    "fields": [
      { "key": "number",          "label": "Incident-Nr.",      "type": "text",     "required": false, "auto": true },
      { "key": "title",           "label": "Titel",             "type": "text",     "required": true,  "auto": false },
      { "key": "description",     "label": "Beschreibung",      "type": "textarea", "required": false, "auto": false },
      { "key": "source",          "label": "Quelle",            "type": "enum",     "required": false, "auto": false,
        "values": ["E-Mail","Telefon","Portal","Monitoring","Intern"] },
      { "key": "reporter",        "label": "Berichterstatter",  "type": "text",     "required": false, "auto": false },
      { "key": "category",        "label": "Kategorie",         "type": "enum",     "required": false, "auto": false,
        "values": ["Hardware","Software","Netzwerk","Zugang","Sicherheit","Sonstiges"] },
      { "key": "subcategory",     "label": "Subkategorie",      "type": "text",     "required": false, "auto": false },
