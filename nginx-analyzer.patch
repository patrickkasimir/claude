# Odoo-Analyzer-Web-App unter /analyzer/ verfügbar machen (Basic-Auth, TLS vorhanden)
# Die App läuft via pm2 auf 127.0.0.1:3010 (pm2 name: odoo-analyzer).
#
# In /etc/nginx/sites-available/codetalk in den 443-Server-Block
# (server_name backend.kasimir.info) einfügen, VOR "location /claudeapps/ {":

    location /analyzer/ {
        proxy_pass http://127.0.0.1:3010/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        # gleiches Login wie der Analyse-Report (Benutzer 'odoo')
        auth_basic "Odoo-Analyzer - Login";
        auth_basic_user_file /etc/nginx/.htpasswd-odoo;

        add_header X-Robots-Tag "noindex, nofollow" always;
    }

# Danach:
#   sudo nginx -t && sudo systemctl reload nginx
#
# Erreichbar (mit Login):  https://backend.kasimir.info/analyzer/
#
# ── Betrieb (pm2) ──
#   pm2 restart odoo-analyzer     # nach Code-Änderungen
#   pm2 logs odoo-analyzer        # Logs ansehen
#
# Hinweis: Die App bindet bewusst nur an 127.0.0.1 – von außen nur über nginx
# (mit Login) erreichbar. Ohne den nginx-Block ist sie nur lokal/per SSH-Tunnel
# erreichbar:  ssh -L 3010:127.0.0.1:3010 <user>@<server>  ->  http://localhost:3010
